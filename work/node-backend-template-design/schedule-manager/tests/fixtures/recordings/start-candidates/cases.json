[
  {
    "id": "non-recurring-passes-first-start-as-occurrence",
    "description": "One-off schedule: SQL already constrained first_start; we copy first_start/end to _occurrence_*.",
    "window": { "start": "2026-05-10 10:00:00", "end": "2026-05-10 10:05:00" },
    "candidates": [
      {
        "id": 1,
        "stream_id": "stream-a",
        "is_recurring": 0,
        "first_start": "2026-05-10 10:00:00",
        "first_end": "2026-05-10 10:30:00",
        "post_id": 100
      }
    ],
    "expected": {
      "includedIds": [1],
      "byId": {
        "1": {
          "_occurrence_start": "2026-05-10 10:00:00",
          "_occurrence_end": "2026-05-10 10:30:00"
        }
      }
    }
  },
