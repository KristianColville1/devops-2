# Schedule Manager — copy to `.env` in this directory; loaded via `src/core/env/bootstrap.ts` (cwd).

PORT=3000
HOST=0.0.0.0

# IANA timezone for wall-clock timestamps (LibSQL + RRULE windows). Default applied in bootstrap: Europe/Dublin.
CCL_SITE_TIMEZONE=Europe/Dublin

# LibSQL (Bunny)
BUNNY_DATABASE_URL=
BUNNY_DATABASE_AUTH_TOKEN=

# Bunny Stream API — same as WordPress `BUNNY_REC_PASS` (video metadata GET for encoding webhook).
BUNNY_REC_PASS=

# Same prefix as WordPress `$wpdb->prefix` (fixed in code as wp_ for this service).
# Same HS256 secret as WordPress `define('PROXY_JWT_SECRET', '...')` — used by
# `src/core/jwt/proxyWordPressJwt.ts` for outbound `ccl_sync/v1` calls and optional verify.
PROXY_JWT_SECRET=

# Lifetime (seconds) for JWT minted to WordPress during rebuild (default 28800 = 8h).
PROXY_JWT_TTL_SECONDS=28800

# WordPress origin for sync (default https://admin.churchcamlive.ie).
CCL_WORDPRESS_REST_ORIGIN=https://admin.churchcamlive.ie

# Per-table HTTP fetch timeout when pulling JSON from WordPress (seconds).
CCL_SYNC_HTTP_TIMEOUT_SECONDS=600

# Optional: require this value as Authorization: Bearer … or X-Sync-Token for POST /api/v1/sync/rebuild-from-wordpress.
SYNC_REBUILD_TOKEN=

# Long-running rebuild (Fastify), milliseconds (default 1 hour).
FASTIFY_REQUEST_TIMEOUT_MS=3600000
FASTIFY_CONNECTION_TIMEOUT_MS=3600000

# Ant Media Server REST — same define names as WordPress `wp-config.php`.
ORIGIN_AMS_SECRET_KEY=
ORIGIN_AMS_BASE_URL=
ORIGIN_FILTER_URL=
PLAYLIST_AMS_SECRET_KEY=
PLAYLIST_AMS_BASE_URL=

# Delay between staggered recording PUTs toward Ant Media (ms). Default 500.
ORIGIN_AMS_RECORDING_BATCH_GAP_MS=500

# Admin React UI: login + HttpOnly session cookie (JWT, 1h). Protects only `/api/v1/admin/*`.
# Optional: same token as `Authorization: Bearer …` for scripts hitting admin routes.
# All other API routes (recordings cron, Bunny webhook, sync health, etc.) are unchanged — no admin cookie required.
SCHEDULE_MANAGER_UI_TOKEN=

# UI: http://localhost:3000/ — operator dashboard after login (`npm run build` in `frontend/` → `public/`).
