{
  "name": "schedule-manager",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:ui": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:backend": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "build:frontend": "npm run build --prefix frontend",
    "start": "node dist/server.js",
    "test": "node scripts/run-tests.mjs",
    "rrule:probe": "tsx scripts/rrule-probe.ts",
    "db:init": "tsx src/core/database/runInitSchema.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@libsql/client": "^0.15.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.2",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "rrule": "^2.8.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "~5.7.3"
  }
}
