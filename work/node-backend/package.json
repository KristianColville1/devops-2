    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/websocket": "^9.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.2",
    "ioredis": "^5.0.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.3",
    "typescript": "~5.7.3",
    "vitest": "^4.1.5"
