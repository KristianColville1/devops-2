# Copy to `.env` — loaded via `src/core/env/bootstrap.ts` (cwd).

PORT=3000
HOST=0.0.0.0

# Fastify timeouts (ms). Defaults shown in `src/core/http/app.ts` if unset.
# FASTIFY_REQUEST_TIMEOUT_MS=300000
# FASTIFY_CONNECTION_TIMEOUT_MS=300000

# DynamoDB
AWS_REGION=us-east-1
DYNAMO_TABLE_NODES=devops-nodes
# Local dev — point at DynamoDB Local and enable table auto-creation on startup.
DYNAMO_ENDPOINT=http://localhost:8000
DYNAMO_LOCAL=true

# EC2 metadata (injected via launch template user data in production; fallbacks used locally).
# EC2_INSTANCE_ID=i-0abc123def456789
# EC2_AZ=us-east-1a
